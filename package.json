{
  "name": "@sirmekus/kwado",
  "version": "1.0.0",
  "description": "Unify Zod validation, react-hook-form, and oku HTTP submission in one hook — with an extensible response-handler pipeline.",
  "keywords": [
    "react",
    "zod",
    "react-hook-form",
    "oku",
    "form",
    "validation",
    "typescript",
    "hooks"
  ],
  "author": "sirmekus (aka Emmy Boy)",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build":     "tsup",
    "dev":       "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=3.0.0",
    "@sirmekus/oku":      ">=1.0.0",
    "react":              ">=18.0.0",
    "react-hook-form":    ">=7.0.0",
    "zod":                ">=3.0.0"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@sirmekus/oku":      "^1.0.0",
    "@types/react":       "^18.3.0",
    "react":              "^18.3.0",
    "react-hook-form":    "^7.56.0",
    "tsup":               "^8.4.0",
    "typescript":         "^5.7.0",
    "zod":                "^3.24.3"
  }
}
