{
  "compilerOptions": {
    "target":            "ES2020",
    "lib":               ["ES2020", "DOM"],
    "module":            "Preserve",
    "moduleResolution":  "Bundler",
    "jsx":               "react-jsx",
    "strict":            true,
    "declaration":       true,
    "declarationMap":    true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "outDir":            "dist"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
